# PostgreSQL — system Postgres 18 on this Mac (see docs/db.md)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/clarwiz?schema=public"

NODE_ENV=development
# NextAuth + AES-256-GCM encryption for stored LinkupAPI account_id
SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL = http://localhost:3000
NEXT_PUBLIC_URL = http://localhost:3000

# NextAuth sign-in + Gmail send (Integrations → Email → Gmail)
GOOGLE_CLIENT_ID =
GOOGLE_CLIENT_SECRET =
# Add authorized redirect URI in Google Cloud: {NEXT_PUBLIC_URL}/api/assist/gmail/oauth/callback

ANTHROPIC_API_KEY=
# Optional — override default Claude models (haiku for simple, sonnet for complex)
# ANTHROPIC_MODEL_SIMPLE=claude-haiku-4-5
# ANTHROPIC_MODEL_COMPLEX=claude-sonnet-4-5

# Smartlead (admin key for inbox connect, warmup, campaigns)
SMARTLEAD_ADMIN_API_KEY=

LINKUP_API_KEY=

# Optional — Meta Graph API version for WhatsApp (default v21.0)
# WHATSAPP_GRAPH_API_VERSION=v21.0
# Use Meta Marketing Messages API for MARKETING-category templates (default: auto by category)
# WHATSAPP_USE_MARKETING_API=true
# Meta webhook verify token — optional one-time bootstrap into DB if tenant row has none yet.
# Prefer entering the token in Integrations → WhatsApp when connecting (stored encrypted per tenant).
# WHATSAPP_META_VERIFY_TOKEN=
# Fallback user id when webhook cannot resolve phone_number_id (single-tenant dev)
# WHATSAPP_WEBHOOK_DEFAULT_USER_ID=
# Interakt webhook shared secret header (optional; prefer DB storage via Settings)
# INTERAKT_WEBHOOK_SECRET=

# Autopilot outreach cron: local dev uses npm run cron:outreach (SECRET + NEXT_PUBLIC_URL).
# Vercel Pro only — merge vercel.cron.pro.example.json into vercel.json, then set:
# OUTREACH_CRON_ENABLED=true
# Max due contacts dispatched per minute (default 100)
# OUTREACH_DISPATCH_LIMIT=100
# Parallel worker HTTP calls per cron tick (default 50; raise for large same-time batches)
# OUTREACH_DISPATCH_CONCURRENCY=50

# Calendly OAuth — two apps (Settings → choose connection type)
# Standard+ plan: auto-qualify when invitee books (webhooks:write)
# CALENDLY_CLIENT_ID=
# CALENDLY_CLIENT_SECRET=
# Free plan: tracked booking link + reply qual only (users:read)
# CALENDLY_FREE_CLIENT_ID=
# CALENDLY_FREE_CLIENT_SECRET=
# CALENDLY_REDIRECT_URI=http://localhost:3000/api/integrations/calendly/oauth/callback
# Public HTTPS URL for Calendly webhooks (required — localhost is rejected)
# CALENDLY_WEBHOOK_URL=https://your-tunnel.ngrok-free.app/api/webhooks/calendly
# Signing key from webhook subscription response (verify POST /api/webhooks/calendly)
# CALENDLY_WEBHOOK_SIGNING_KEY=

# Vercel / Next.js serverless max duration in seconds (hobby plan max 300; use 600 locally)
SERVERLESS_MAX_DURATION=600

# GTM Core — ICP analysis tools (Settings → Workspace)
GTM_CORE_API_KEY=
# GTM_CORE_API_BASE_URL=https://gtm-core.vercel.app/api/tools
# Per-step timeout in ms (default 600000 = 10 min)
# GTM_CORE_API_TIMEOUT_MS=600000
# Retries when upstream closes connection (default 2)
# GTM_CORE_RETRY_ATTEMPTS=2

# HubSpot OAuth public app (AE Assist → Connect HubSpot)
# HUBSPOT_CLIENT_ID=
# HUBSPOT_CLIENT_SECRET=
# HUBSPOT_REDIRECT_URI=http://localhost:3000/api/assist/hubspot/oauth/callback
# Required scopes (space-separated) — must match your HubSpot app config
# HUBSPOT_OAUTH_SCOPES="oauth crm.objects.contacts.read crm.objects.companies.read crm.objects.companies.write crm.objects.deals.read crm.objects.deals.write crm.schemas.deals.read crm.schemas.contacts.read crm.objects.leads.read crm.objects.leads.write crm.lists.read sales-email-read"
# Optional scopes (space-separated) — granted when the portal supports them
# HUBSPOT_OAUTH_OPTIONAL_SCOPES="crm.objects.appointments.read crm.objects.appointments.write crm.objects.calls.read crm.extensions_calling_transcripts.read transactional-email crm.objects.owners.read"
# Dev seed only (scripts/seed-mofu-demo.js) — not used by the app runtime
# HUBSPOT_DEV_ACCESS_TOKEN=
# HUBSPOT_TEST_PORTAL_ID=
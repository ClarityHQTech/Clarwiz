generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantRole {
  ADMIN  @map("admin")
  MEMBER @map("member")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum ContactPersona {
  DECISION_MAKER
  INFLUENCER
  CHAMPION
  GATEKEEPER
  ECONOMIC_BUYER
  TECHNICAL_BUYER
  END_USER
  OTHER
}

enum ContactCampaignStatus {
  PENDING
  IN_OUTREACH
  REPLIED
  QUALIFIED
  NOT_QUALIFIED
  DISQUALIFIED
  PAUSED
}

model Company {
  id            String         @id @default(cuid())
  name          String
  domain        String?
  industry      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  businessUsers BusinessUser[]

  @@unique([name])
}

model BusinessUser {
  id          String               @id @default(cuid())
  companyId   String?
  company     Company?             @relation(fields: [companyId], references: [id], onDelete: SetNull)
  name        String
  firstName   String?
  lastName    String?
  jobTitle    String?
  department  String?
  seniority   String?
  email       String?
  phone       String?
  whatsapp    String?
  linkedinUrl String?
  twitterId   String?
  location    String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  contacts    Contact[]
  signals     BusinessUserSignal[]

  @@index([email])
  @@index([linkedinUrl])
  @@index([companyId])
}

model BusinessUserSignal {
  id             String       @id @default(cuid())
  businessUserId String
  businessUser   BusinessUser @relation(fields: [businessUserId], references: [id], onDelete: Cascade)
  tenantId       String?
  campaignId     String?
  type           String
  source         String
  content        String
  createdAt      DateTime     @default(now())

  @@index([businessUserId])
  @@index([tenantId])
  @@index([campaignId])
  @@index([businessUserId, campaignId])
}

model User {
  id              String             @id @default(cuid())
  email           String             @unique
  name            String?
  image           String?
  is_superadmin   Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  memberships     TenantMembership[]
  invitationsSent TenantInvitation[] @relation("InvitedBy")
}

model Tenant {
  id                  String               @id @default(cuid())
  name                String
  company_details     Json?
  payment_status      Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  memberships         TenantMembership[]
  invitations         TenantInvitation[]
  campaigns           Campaign[]
  contacts            Contact[]
  commLogs            CommunicationLog[]
  apiKeys             ExternalApiKey[]
  linkedInIntegration LinkedInIntegration?
  emailIntegration    EmailIntegration?
  whatsappIntegration WhatsAppIntegration?
  calendlyIntegration CalendlyIntegration?
  tenantIcpContext    TenantIcpContext?
  integrationWebhooks IntegrationWebhook[]
  hubspotIntegration  HubSpotIntegration?
  deals               Deal[]
}

model ExternalApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  prefix     String
  keyHash    String    @unique
  scopes     String[]  @default([])
  createdBy  String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, revokedAt])
  @@index([tenantId, expiresAt])
}

model TenantMembership {
  id        String     @id @default(cuid())
  tenantId  String     @map("tenant_id")
  userId    String     @map("user_id")
  role      TenantRole
  scopes    String[]   @default([])
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("user_tenant_roles")
}

model TenantInvitation {
  id          String           @id @default(cuid())
  tenantId    String
  email       String
  role        TenantRole
  scopes      String[]         @default([])
  token       String           @unique
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  invitedById String
  createdAt   DateTime         @default(now())
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy   User             @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([tenantId, email])
  @@index([token])
}

/// Per-tenant ICP workbook and GTM Core tool outputs for execution-layer context
model TenantIcpContext {
  id               String    @id @default(cuid())
  tenantId         String    @unique
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyName      String?
  companyDomain    String?
  relevantData     String?   @db.Text
  userQuery        String?
  accountData      String?   @db.Text
  status           String    @default("draft")
  currentStep      String?
  icpGapAnalysis   String?   @db.Text
  marketResearch   String?   @db.Text
  valueProposition String?   @db.Text
  icpWorkbook      String?   @db.Text
  accountSignals   String?   @db.Text
  lastError        String?
  analyzedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model LinkedInIntegration {
  id              String    @id @default(cuid())
  tenantId        String    @unique
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  linkupAccountId String
  accountName     String?
  email           String?
  status          String    @default("pending")
  challengeType   String?
  country         String    @default("US")
  connectedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model EmailIntegration {
  id                          String    @id @default(cuid())
  tenantId                    String    @unique
  tenant                      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mode                        String    @default("smartlead_inbox")
  status                      String    @default("pending")
  fromEmail                   String?
  fromName                    String?
  sendingDomain               String?
  providerType                String?
  encryptedSmartleadAccountId String?
  customTrackingDomain        String?
  isSmtpSuccess               Boolean?
  isImapSuccess               Boolean?
  warmupEnabled               Boolean   @default(true)
  warmupStatus                String?
  warmupReputation            String?
  connectedAt                 DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
}

model CalendlyIntegration {
  id                      String    @id @default(cuid())
  tenantId                String    @unique
  tenant                  Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  encryptedAccessToken    String
  encryptedRefreshToken   String?
  organizationUri         String?
  userUri                 String?
  ownerEmail              String?
  status                  String    @default("pending")
  connectionMode          String    @default("webhooks")
  webhookSubscriptionUris Json?
  connectedAt             DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

model WhatsAppIntegration {
  id                   String    @id @default(cuid())
  tenantId             String    @unique
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mode                 String
  status               String    @default("pending")
  encryptedAccessToken String
  phoneNumberId        String?
  wabaId               String?
  encryptedMetaToken   String?
  businessPhone        String?
  businessName         String?
  templatesCache       Json?
  templatesCachedAt    DateTime?
  connectedAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Campaign {
  id                  String                  @id @default(cuid())
  tenantId            String
  tenant              Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                String
  description         String?
  targetSegment       String?
  goals               String?
  startDate           DateTime?
  status              String                  @default("draft")
  sentCount           Int                     @default(0)
  openRate            Float                   @default(0)
  replyRate           Float                   @default(0)
  qualifiedLeads      Int                     @default(0)
  calendlyBookingUrl  String?
  smartleadCampaignId Int?
  outreachTimezone    String                  @default("UTC")
  defaultOutreachTime String                  @default("11:00")
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  contactCampaigns    ContactCampaign[]
  templates           CommunicationTemplate[]
  commLogs            CommunicationLog[]

  @@index([tenantId])
}

model Contact {
  id               String            @id @default(cuid())
  tenantId         String
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  businessUserId   String
  businessUser     BusinessUser      @relation(fields: [businessUserId], references: [id], onDelete: Restrict)
  persona          ContactPersona    @default(OTHER)
  mqlAt            DateTime?
  promotedDealId   String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  contactCampaigns ContactCampaign[]

  @@unique([tenantId, businessUserId])
  @@index([tenantId])
  @@index([businessUserId])
}

model ContactCampaign {
  id                      String                @id @default(cuid())
  contactId               String
  campaignId              String
  status                  ContactCampaignStatus @default(PENDING)
  qualifiedAt             DateTime?
  qualifiedReason         String?
  outreachDeliveryTime    String?
  nextScheduledOutreachAt DateTime?
  lastOutreachDate        DateTime?             @db.Date
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  contact                 Contact               @relation(fields: [contactId], references: [id], onDelete: Cascade)
  campaign                Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  commLogs                CommunicationLog[]

  @@unique([contactId, campaignId])
  @@index([campaignId])
  @@index([campaignId, nextScheduledOutreachAt])
  @@index([campaignId, status])
}

model CommunicationLog {
  id                String          @id @default(cuid())
  tenantId          String
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaignId        String
  campaign          Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactCampaignId String
  contactCampaign   ContactCampaign @relation(fields: [contactCampaignId], references: [id], onDelete: Cascade)
  channel           String
  templateId        String?
  stage             Int?
  subject           String?
  message           String
  ctaType           String?
  status            String          @default("planned")
  sentAt            DateTime        @default(now())
  deliveredAt       DateTime?
  openedAt          DateTime?
  ctaClickedAt      DateTime?
  responseType      String?
  responseAt        DateTime?
  responseContent   String?
  signalRef         String?
  decisionReason    String?
  modelUsed           String?
  providerUsage       Json?
  providerCost        Json?
  deliveryProvider    String?
  deliveryMeta        Json?
  scheduledFor        DateTime?
  retryCount          Int             @default(0)
  lastRetryAt         DateTime?
  nextRetryAt         DateTime?
  createdAt           DateTime        @default(now())

  @@index([tenantId])
  @@index([tenantId, sentAt])
  @@index([campaignId])
  @@index([contactCampaignId])
  @@index([campaignId, contactCampaignId])
  @@index([status, scheduledFor])
  @@index([status, nextRetryAt])
}

model IntegrationWebhook {
  id                     String    @id @default(cuid())
  tenantId               String
  tenant                 Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider               String
  webhookToken           String    @unique @default(cuid())
  status                 String    @default("pending")
  providerWebhookId      String?
  webhookUrl             String?
  encryptedSigningSecret String?
  encryptedVerifyToken   String?
  eventsSubscribed       Json?
  lastEventAt            DateTime?
  lastError              String?
  providerMeta           Json?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@unique([tenantId, provider])
  @@index([tenantId])
  @@index([webhookToken])
}

model CommunicationTemplate {
  id                      String   @id @default(cuid())
  campaignId              String
  campaign                Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  channel                 String
  stage                   Int      @default(1)
  subject                 String?
  body                    String
  cta                     String
  whatsappTemplateId      String?
  whatsappVariableMapping Json?
  createdAt               DateTime @default(now())

  @@index([campaignId])
}

// ===================== MOFU (HubSpot-as-SOR) — additive =====================

enum DealSource {
  TOFU_TRANSITION
  HUBSPOT_MQL
  MANUAL
}

enum InsightScope {
  DEAL
  COMPANY
}

enum DealSignalKind {
  CALL_TRANSCRIPT
  EMAIL
  STAGE_CHANGE
  MEETING
  NOTE
}

enum NbaActionType {
  SEND_EMAIL
  SEND_MARKETING_COLLATERAL
  SEND_SALES_COLLATERAL
  SCHEDULE_MEETING
  CALL_WITH_SCRIPT
  PREP_MEETING
  UPDATE_CRM_CREATE_TASK
  NOTIFY_TEAM
}

enum NbaStatus {
  SUGGESTED
  DRAFTED
  EDITED
  APPROVED
  SENT
  DISMISSED
  FAILED
}

enum CapabilityKind {
  NOTE_TAKER
  CALLING
  EMAIL
  MEETING_SCHEDULER
}

enum DocumentType {
  MARKETING_COLLATERAL
  SALES_COLLATERAL
  BATTLECARD
  EMAIL_ATTACHMENT
}

enum DocumentPath {
  A
  B
}

enum DocumentStatus {
  DRAFT
  READY
  SENT
}

model HubSpotIntegration {
  id                    String    @id @default(cuid())
  tenantId              String    @unique
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  portalId              String?
  encryptedAccessToken  String?
  encryptedRefreshToken String?
  tokenExpiresAt        DateTime?
  scopes                String[]  @default([])
  status                String    @default("pending")
  lastError             String?
  connectedAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Deal {
  id                      String              @id @default(cuid())
  tenantId                String
  tenant                  Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  hubspotDealId           String
  name                    String?
  cachedStage             String?
  cachedOwner             String?
  cachedAmount            Float?
  cachedCurrency          String?
  stageSnapshotAt         DateTime?
  originContactCampaignId String?
  source                  DealSource          @default(MANUAL)
  autopilot               Boolean             @default(false)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  context                 DealContext?
  signals                 DealSignal[]
  insights                DealInsight[]
  recommendations         NbaRecommendation[]
  documents               Document[]

  @@unique([tenantId, hubspotDealId])
  @@index([tenantId])
}

model DealContext {
  id           String   @id @default(cuid())
  tenantId     String
  dealId       String   @unique
  deal         Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  data         Json
  sourceRefs   Json?
  lastSyncedAt DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
}

model DealSignal {
  id                String         @id @default(cuid())
  tenantId          String
  dealId            String
  deal              Deal           @relation(fields: [dealId], references: [id], onDelete: Cascade)
  scope             InsightScope   @default(DEAL)
  kind              DealSignalKind
  source            String
  externalId        String
  summary           String?
  score             Float          @default(0)
  signalReferenceId String
  contactId         String?
  occurredAt        DateTime?
  raw               Json?
  processedForNbaAt DateTime?
  createdAt         DateTime       @default(now())

  @@unique([tenantId, source, kind, externalId])
  @@index([tenantId, dealId])
  @@index([tenantId, contactId])
}

model DealInsight {
  id                        String       @id @default(cuid())
  tenantId                  String
  scope                     InsightScope
  dealId                    String?
  deal                      Deal?        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  companyId                 String?
  executiveSummary          Json?
  stakeholderIntelligence   Json?
  valueIntelligence         Json?
  riskIntelligence          Json?
  temporalIntelligence      Json?
  competitiveIntelligence   Json?
  expansionIntelligence     Json?
  actionableRecommendations Json?
  systemMetadata            Json?
  modelUsed                 String?
  providerUsage             Json?
  providerCost              Json?
  createdAt                 DateTime     @default(now())

  @@index([tenantId, dealId])
  @@index([tenantId, companyId])
}

model TenantCapability {
  id           String         @id @default(cuid())
  tenantId     String
  capability   CapabilityKind
  present      Boolean        @default(false)
  detail       Json?
  discoveredAt DateTime       @default(now())

  @@unique([tenantId, capability])
  @@index([tenantId])
}

model NbaTemplate {
  id                   String        @id @default(cuid())
  tenantId             String?
  actionType           NbaActionType
  title                String
  collateralTemplateId String?
  promptScaffold       String?       @db.Text
  guardrails           Json?
  enabled              Boolean       @default(true)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([tenantId])
}

model NbaRecommendation {
  id                  String        @id @default(cuid())
  tenantId            String
  dealId              String
  deal                Deal          @relation(fields: [dealId], references: [id], onDelete: Cascade)
  scope               InsightScope  @default(DEAL)
  actionType          NbaActionType
  title               String
  score               Float         @default(0)
  signalReferenceId   String?
  payload             Json?
  templateId          String?
  status              NbaStatus     @default(SUGGESTED)
  juryResult          Json?
  modelUsed           String?
  providerUsage       Json?
  providerCost        Json?
  executedAt          DateTime?
  hubspotEngagementId String?
  createdAt           DateTime      @default(now())

  @@index([tenantId, dealId])
}

model Document {
  id                  String         @id @default(cuid())
  tenantId            String
  dealId              String
  deal                Deal           @relation(fields: [dealId], references: [id], onDelete: Cascade)
  nbaRecommendationId String?
  type                DocumentType
  path                DocumentPath?
  category            String?
  sourceTemplateId    String?
  contentJson         Json?
  renderedHtml        String?        @db.Text
  pdfUrl              String?
  brand               Json?
  version             Int            @default(1)
  status              DocumentStatus @default(DRAFT)
  modelUsed           String?
  providerUsage       Json?
  providerCost        Json?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([tenantId, dealId])
}

model CollateralTemplate {
  id         String   @id @default(cuid())
  tenantId   String?
  templateId String
  title      String
  html       String   @db.Text
  schema     Json?
  category   String   @default("marketing")
  scope      String   @default("tenant")
  source     String   @default("uploaded")
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
}

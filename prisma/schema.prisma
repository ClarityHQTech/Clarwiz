generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantRole {
  ADMIN  @map("admin")
  MEMBER @map("member")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum ContactPersona {
  DECISION_MAKER
  INFLUENCER
  CHAMPION
  GATEKEEPER
  ECONOMIC_BUYER
  TECHNICAL_BUYER
  END_USER
  OTHER
}

enum ContactCampaignStatus {
  PENDING
  IN_OUTREACH
  REPLIED
  QUALIFIED
  NOT_QUALIFIED
  DISQUALIFIED
  PAUSED
}

// ── MOFU (AE Assist) layer ──────────────────────────────────────────────
enum DealStageBand {
  LEAD
  DEAL_EARLY
  DEAL_LATE
}

enum DealStatus {
  OPEN
  WON
  LOST
}

enum NbaStatus {
  SUGGESTED
  DRAFTED
  APPROVED
  EXECUTED
  DISMISSED
}

enum CollateralType {
  MARKETING_DOC
  PITCH_DECK
  BATTLECARD
  ONE_PAGER
  CASE_STUDY
  EMAIL_TEMPLATE
  OTHER
}

enum CollateralSrc {
  GENERATED
  HEYPARROT
  PILOT
  UPLOAD
}

enum CollateralCategory {
  MARKETING
  SALES
}

enum FunnelStage {
  LEAD
  DEAL_EARLY
  DEAL_LATE
  ANY
}

enum AssistAction {
  INSIGHT_COMPUTED
  NBA_DRAFTED
  NBA_EXECUTED
  EMAIL_DRAFTED
  COLLATERAL_SENT
  TASK_CREATED
  NOTE_ADDED
  DEAL_CREATED
  MEETING_SCHEDULED
  CHAT_QUERY
}

model Company {
  id            String         @id @default(cuid())
  name          String
  domain        String?
  industry      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  businessUsers BusinessUser[]
  accounts      Account[]

  @@unique([name])
}

model BusinessUser {
  id          String               @id @default(cuid())
  companyId   String?
  company     Company?             @relation(fields: [companyId], references: [id], onDelete: SetNull)
  name        String
  firstName   String?
  lastName    String?
  jobTitle    String?
  department  String?
  seniority   String?
  email       String?
  phone       String?
  whatsapp    String?
  linkedinUrl String?
  twitterId   String?
  location    String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  contacts    Contact[]
  signals     BusinessUserSignal[]

  @@index([email])
  @@index([linkedinUrl])
  @@index([companyId])
}

model BusinessUserSignal {
  id             String       @id @default(cuid())
  businessUserId String
  businessUser   BusinessUser @relation(fields: [businessUserId], references: [id], onDelete: Cascade)
  tenantId       String?
  campaignId     String?
  type           String
  source         String
  content        String
  createdAt      DateTime     @default(now())

  @@index([businessUserId])
  @@index([tenantId])
  @@index([campaignId])
  @@index([businessUserId, campaignId])
}

model User {
  id              String             @id @default(cuid())
  email           String             @unique
  name            String?
  image           String?
  is_superadmin   Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  memberships     TenantMembership[]
  invitationsSent TenantInvitation[] @relation("InvitedBy")
}

model Tenant {
  id                  String               @id @default(cuid())
  name                String
  company_details     Json?
  payment_status      Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  memberships         TenantMembership[]
  invitations         TenantInvitation[]
  campaigns           Campaign[]
  contacts            Contact[]
  commLogs            CommunicationLog[]
  apiKeys             ExternalApiKey[]
  linkedInIntegration LinkedInIntegration?
  emailIntegration    EmailIntegration?
  whatsappIntegration WhatsAppIntegration?
  calendlyIntegration CalendlyIntegration?
  tenantIcpContext    TenantIcpContext?
  integrationWebhooks IntegrationWebhook[]
  mofuIntegration     MofuIntegration?
  accounts            Account[]
  deals               Deal[]
  dealInsights        DealInsight[]
  companyInsights     CompanyInsight[]
  nbas                NbaRecommendation[]
  signals             Signal[]
  collateralIndex     CollateralIndex[]
  assistActionLogs    AssistActionLog[]
  documents           Document[]
}

model ExternalApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  prefix     String
  keyHash    String    @unique
  scopes     String[]  @default([])
  createdBy  String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, revokedAt])
  @@index([tenantId, expiresAt])
}

model TenantMembership {
  id        String     @id @default(cuid())
  tenantId  String     @map("tenant_id")
  userId    String     @map("user_id")
  role      TenantRole
  scopes    String[]   @default([])
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("user_tenant_roles")
}

model TenantInvitation {
  id          String           @id @default(cuid())
  tenantId    String
  email       String
  role        TenantRole
  scopes      String[]         @default([])
  token       String           @unique
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  invitedById String
  createdAt   DateTime         @default(now())
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy   User             @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([tenantId, email])
  @@index([token])
}

/// Per-tenant ICP workbook and GTM Core tool outputs for execution-layer context
model TenantIcpContext {
  id               String    @id @default(cuid())
  tenantId         String    @unique
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyName      String?
  companyDomain    String?
  relevantData     String?   @db.Text
  userQuery        String?
  accountData      String?   @db.Text
  status           String    @default("draft")
  currentStep      String?
  icpGapAnalysis   String?   @db.Text
  marketResearch   String?   @db.Text
  valueProposition String?   @db.Text
  icpWorkbook      String?   @db.Text
  accountSignals   String?   @db.Text
  lastError        String?
  analyzedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model LinkedInIntegration {
  id              String    @id @default(cuid())
  tenantId        String    @unique
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  linkupAccountId String
  accountName     String?
  email           String?
  status          String    @default("pending")
  challengeType   String?
  country         String    @default("US")
  connectedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model EmailIntegration {
  id                          String    @id @default(cuid())
  tenantId                    String    @unique
  tenant                      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mode                        String    @default("smartlead_inbox")
  status                      String    @default("pending")
  fromEmail                   String?
  fromName                    String?
  sendingDomain               String?
  providerType                String?
  encryptedSmartleadAccountId String?
  customTrackingDomain        String?
  isSmtpSuccess               Boolean?
  isImapSuccess               Boolean?
  warmupEnabled               Boolean   @default(true)
  warmupStatus                String?
  warmupReputation            String?
  connectedAt                 DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
}

model CalendlyIntegration {
  id                      String    @id @default(cuid())
  tenantId                String    @unique
  tenant                  Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  encryptedAccessToken    String
  encryptedRefreshToken   String?
  organizationUri         String?
  userUri                 String?
  ownerEmail              String?
  status                  String    @default("pending")
  connectionMode          String    @default("webhooks")
  webhookSubscriptionUris Json?
  connectedAt             DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

model WhatsAppIntegration {
  id                   String    @id @default(cuid())
  tenantId             String    @unique
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mode                 String
  status               String    @default("pending")
  encryptedAccessToken String
  phoneNumberId        String?
  wabaId               String?
  encryptedMetaToken   String?
  businessPhone        String?
  businessName         String?
  templatesCache       Json?
  templatesCachedAt    DateTime?
  connectedAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Campaign {
  id                  String                  @id @default(cuid())
  tenantId            String
  tenant              Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                String
  description         String?
  targetSegment       String?
  goals               String?
  startDate           DateTime?
  status              String                  @default("draft")
  sentCount           Int                     @default(0)
  openRate            Float                   @default(0)
  replyRate           Float                   @default(0)
  qualifiedLeads      Int                     @default(0)
  calendlyBookingUrl  String?
  smartleadCampaignId Int?
  outreachTimezone    String                  @default("UTC")
  defaultOutreachTime String                  @default("11:00")
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  contactCampaigns    ContactCampaign[]
  templates           CommunicationTemplate[]
  commLogs            CommunicationLog[]

  @@index([tenantId])
}

model Contact {
  id               String              @id @default(cuid())
  tenantId         String
  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  businessUserId   String
  businessUser     BusinessUser        @relation(fields: [businessUserId], references: [id], onDelete: Restrict)
  persona          ContactPersona      @default(OTHER)
  hubspotContactId String?
  lifecycleStage   String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  contactCampaigns ContactCampaign[]
  dealContacts     DealContact[]
  nbas             NbaRecommendation[]

  @@unique([tenantId, businessUserId])
  @@unique([tenantId, hubspotContactId])
  @@index([tenantId])
  @@index([businessUserId])
}

model ContactCampaign {
  id                      String                @id @default(cuid())
  contactId               String
  campaignId              String
  status                  ContactCampaignStatus @default(PENDING)
  qualifiedAt             DateTime?
  qualifiedReason         String?
  outreachDeliveryTime    String?
  nextScheduledOutreachAt DateTime?
  lastOutreachDate        DateTime?             @db.Date
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  contact                 Contact               @relation(fields: [contactId], references: [id], onDelete: Cascade)
  campaign                Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  commLogs                CommunicationLog[]

  @@unique([contactId, campaignId])
  @@index([campaignId])
  @@index([campaignId, nextScheduledOutreachAt])
  @@index([campaignId, status])
}

model CommunicationLog {
  id                String          @id @default(cuid())
  tenantId          String
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaignId        String
  campaign          Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactCampaignId String
  contactCampaign   ContactCampaign @relation(fields: [contactCampaignId], references: [id], onDelete: Cascade)
  channel           String
  templateId        String?
  stage             Int?
  subject           String?
  message           String
  ctaType           String?
  status            String          @default("planned")
  sentAt            DateTime        @default(now())
  deliveredAt       DateTime?
  openedAt          DateTime?
  ctaClickedAt      DateTime?
  responseType      String?
  responseAt        DateTime?
  responseContent   String?
  signalRef         String?
  decisionReason    String?
  modelUsed         String?
  providerUsage     Json?
  providerCost      Json?
  deliveryProvider  String?
  deliveryMeta      Json?
  scheduledFor      DateTime?
  retryCount        Int             @default(0)
  lastRetryAt       DateTime?
  nextRetryAt       DateTime?
  createdAt         DateTime        @default(now())

  @@index([tenantId])
  @@index([tenantId, sentAt])
  @@index([campaignId])
  @@index([contactCampaignId])
  @@index([campaignId, contactCampaignId])
  @@index([status, scheduledFor])
  @@index([status, nextRetryAt])
}

model IntegrationWebhook {
  id                     String    @id @default(cuid())
  tenantId               String
  tenant                 Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider               String
  webhookToken           String    @unique @default(cuid())
  status                 String    @default("pending")
  providerWebhookId      String?
  webhookUrl             String?
  encryptedSigningSecret String?
  encryptedVerifyToken   String?
  eventsSubscribed       Json?
  lastEventAt            DateTime?
  lastError              String?
  providerMeta           Json?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@unique([tenantId, provider])
  @@index([tenantId])
  @@index([webhookToken])
}

model CommunicationTemplate {
  id                      String   @id @default(cuid())
  campaignId              String
  campaign                Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  channel                 String
  stage                   Int      @default(1)
  subject                 String?
  body                    String
  cta                     String
  whatsappTemplateId      String?
  whatsappVariableMapping Json?
  createdAt               DateTime @default(now())

  @@index([campaignId])
}

// ── MOFU (AE Assist) layer — intelligence over the shared CRM graph ──────
// SOR stays HubSpot; these mirror + store Clarwiz-computed intelligence.

/// Per-tenant MOFU config: HubSpot creds + LLM/prompt config (mirrors LinkedInIntegration).
model MofuIntegration {
  id                    String    @id @default(cuid())
  tenantId              String    @unique
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  encryptedHubspotToken String
  hubspotPortalId       String?
  defaultOwnerId        String?
  insightModel          String?
  promptVersion         String?
  status                String    @default("pending")
  connectedAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

/// Tenant ↔ Company bridge (company-side mirror of Contact) + HubSpot linkage.
model Account {
  id               String           @id @default(cuid())
  tenantId         String
  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyId        String?
  company          Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  hubspotCompanyId String
  ownerId          String?
  lifecycleStage   String?
  payload          Json?
  syncedAt         DateTime         @default(now())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deals            Deal[]
  companyInsights  CompanyInsight[]
  signals          Signal[]

  @@unique([tenantId, hubspotCompanyId])
  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@index([companyId])
}

/// Tenant-scoped deal mirror + the anchor for all deal intelligence.
model Deal {
  id             String              @id @default(cuid())
  tenantId       String
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accountId      String?
  account        Account?            @relation(fields: [accountId], references: [id], onDelete: SetNull)
  hubspotDealId  String
  name           String
  stageLabel     String?
  stageBand      DealStageBand?
  amount         Float?
  status         DealStatus          @default(OPEN)
  ownerId        String?
  score          Int?
  lastActivityAt DateTime?
  payload        Json?
  syncedAt       DateTime            @default(now())
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  insights       DealInsight[]
  nbas           NbaRecommendation[]
  signals        Signal[]
  dealContacts   DealContact[]

  @@unique([tenantId, hubspotDealId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([accountId])
  @@index([tenantId, ownerId])
}

/// Deal ↔ Contact stakeholders (reuses the shared Contact graph).
model DealContact {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  role      String?
  createdAt DateTime @default(now())

  @@unique([dealId, contactId])
  @@index([contactId])
}

/// Stored computed deal intelligence (AURA-structured payload, computed in Clarwiz).
model DealInsight {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dealId        String
  deal          Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  score         Int?
  briefing      String?  @db.Text
  summary       String?  @db.Text
  payload       Json
  model         String?
  promptVersion String?
  tokensUsed    Json?
  computedAt    DateTime @default(now())

  @@index([dealId])
  @@index([tenantId, computedAt])
}

/// Stored computed company intelligence (the 10-tab payload).
model CompanyInsight {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accountId     String
  account       Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  payload       Json
  model         String?
  promptVersion String?
  tokensUsed    Json?
  computedAt    DateTime @default(now())

  @@index([accountId])
  @@index([tenantId, computedAt])
}

/// Next best actions — computed in Clarwiz, with draft→approve→execute lifecycle.
model NbaRecommendation {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dealId       String?
  deal         Deal?     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contactId    String?
  contact      Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  signalId     String?
  signal       Signal?   @relation(fields: [signalId], references: [id], onDelete: SetNull)
  actionType   String // high-level type: draft_email | schedule_meeting | create_task | send_collateral | clarify_technical
  actionVerb   String? // ontology GTM verb, e.g. "Sales::Negotiate", "Shared::Escalate"
  title        String
  score        Int       @default(0)
  rationale    String?   @db.Text
  status       NbaStatus @default(SUGGESTED)
  payload      Json? // full AURA nba_action object (asset, email_detail, mental_model_reasoning_summary, …)
  draftPayload Json? // generated email/collateral draft on execution
  executedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([tenantId])
  @@index([dealId])
  @@index([tenantId, status])
}

/// MOFU buying/risk signals over the context (distinct from TOFU's BusinessUserSignal).
model Signal {
  id             String              @id @default(cuid())
  tenantId       String
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dealId         String?
  deal           Deal?               @relation(fields: [dealId], references: [id], onDelete: Cascade)
  accountId      String?
  account        Account?            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type           String // ontology signal_type, e.g. "Behavior::Response_Time_Decay"
  category       String? // denormalized noun category, e.g. "Behavior" (part before ::)
  tier           Int?
  score          Int? // signal_score 0-100
  confidence     Int? // extraction confidence 0-100
  headline       String
  evidence       String?             @db.Text
  sourceUrl      String?
  suggestedAngle String?             @db.Text
  slaHours       Int?
  payload        Json? // full AURA signal object (quotes, raised_by, handling_effectiveness, …)
  detectedAt     DateTime            @default(now())
  createdAt      DateTime            @default(now())
  nbas           NbaRecommendation[]

  @@index([tenantId])
  @@index([dealId])
  @@index([tenantId, category])
}

/// Unified marketing + sales collateral directory.
model CollateralIndex {
  id          String              @id @default(cuid())
  tenantId    String
  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  type        CollateralType
  category    CollateralCategory?
  source      CollateralSrc
  isTemplate  Boolean             @default(false)
  externalId  String?
  slug        String?
  url         String?
  funnelStage FunnelStage         @default(ANY)
  tags        String[]            @default([])
  companyHsId String?
  dealHsId    String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, funnelStage])
  @@index([tenantId, isTemplate])
  @@index([tenantId, companyHsId])
}

/// Append-only audit + activity feed — the demo narrative.
model AssistActionLog {
  id          String       @id @default(cuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorUserId String?
  entityType  String
  hsObjectId  String?
  action      AssistAction
  payload     Json?
  createdAt   DateTime     @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, hsObjectId])
}

/// AI-generated sales collateral (Tailspin/AURA). Stores the generated React
/// `template` + structured `data` + `compliance`, registered in CollateralIndex.
model Document {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  collateralId  String?
  dealHsId      String?
  companyHsId   String?
  title         String
  template      String   @db.Text
  html          String?  @db.Text
  data          Json?
  compliance    Json?
  versions      Json?
  model         String?
  promptVersion String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantRole {
  ADMIN  @map("admin")
  MEMBER @map("member")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  name         String?
  image        String?
  is_superadmin Boolean          @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  memberships  TenantMembership[]
  invitationsSent TenantInvitation[] @relation("InvitedBy")
}

model Tenant {
  id                  String               @id @default(cuid())
  name                String
  company_details     Json?
  payment_status      Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  memberships         TenantMembership[]
  invitations         TenantInvitation[]
  campaigns           Campaign[]
  commLogs            CommunicationLog[]
  signals             ProspectSignal[]
  apiKeys             ExternalApiKey[]
  linkedInIntegration LinkedInIntegration?
  emailIntegration    EmailIntegration?
  whatsappIntegration WhatsAppIntegration?
  calendlyIntegration CalendlyIntegration?
  tenantIcpContext    TenantIcpContext?
}

model ExternalApiKey {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  prefix     String
  keyHash    String   @unique
  scopes     String[] @default([])
  createdBy  String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, revokedAt])
  @@index([tenantId, expiresAt])
}

model TenantMembership {
  id          String     @id @default(cuid())
  tenantId    String     @map("tenant_id")
  userId      String     @map("user_id")
  role        TenantRole
  scopes      String[]   @default([])
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("user_tenant_roles")
}

model TenantInvitation {
  id          String           @id @default(cuid())
  tenantId    String
  email       String
  role        TenantRole
  scopes      String[]         @default([])
  token       String           @unique
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  invitedById String
  createdAt   DateTime         @default(now())
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy   User             @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([tenantId, email])
  @@index([token])
}

/// Per-tenant ICP workbook and GTM Core tool outputs for execution-layer context
model TenantIcpContext {
  id               String    @id @default(cuid())
  tenantId         String    @unique
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyName      String?
  companyDomain    String?
  relevantData     String?   @db.Text
  userQuery        String?
  accountData      String?   @db.Text
  status           String    @default("draft")
  currentStep      String?
  icpGapAnalysis    String?   @db.Text
  marketResearch   String?   @db.Text
  valueProposition String?   @db.Text
  icpWorkbook      String?   @db.Text
  accountSignals   String?   @db.Text
  lastError        String?
  analyzedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model LinkedInIntegration {
  id              String    @id @default(cuid())
  tenantId        String    @unique
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  linkupAccountId String
  accountName     String?
  email           String?
  status          String    @default("pending")
  challengeType   String?
  country         String    @default("US")
  connectedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model EmailIntegration {
  id                          String    @id @default(cuid())
  tenantId                    String    @unique
  tenant                      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mode                        String    @default("smartlead_inbox")
  status                      String    @default("pending")
  fromEmail                   String?
  fromName                    String?
  sendingDomain               String?
  providerType                String?
  encryptedSmartleadAccountId String?
  customTrackingDomain        String?
  isSmtpSuccess               Boolean?
  isImapSuccess               Boolean?
  warmupEnabled               Boolean   @default(true)
  warmupStatus                String?
  warmupReputation            String?
  connectedAt                 DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
}

model CalendlyIntegration {
  id                      String    @id @default(cuid())
  tenantId                String    @unique
  tenant                  Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  encryptedAccessToken    String
  encryptedRefreshToken   String?
  organizationUri         String?
  userUri                 String?
  ownerEmail              String?
  status                  String    @default("pending")
  connectionMode          String    @default("webhooks")
  webhookSubscriptionUris Json?
  connectedAt             DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

model WhatsAppIntegration {
  id                   String    @id @default(cuid())
  tenantId             String    @unique
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mode                 String
  status               String    @default("pending")
  encryptedAccessToken String
  phoneNumberId        String?
  wabaId               String?
  encryptedMetaToken   String?
  businessPhone        String?
  businessName         String?
  templatesCache       Json?
  templatesCachedAt    DateTime?
  connectedAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Campaign {
  id                 String                  @id @default(cuid())
  tenantId           String
  tenant             Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name               String
  description        String?
  targetSegment      String?
  goals              String?
  startDate          DateTime?
  status             String                  @default("draft")
  sentCount          Int                     @default(0)
  openRate           Float                   @default(0)
  replyRate          Float                   @default(0)
  qualifiedLeads     Int                     @default(0)
  calendlyBookingUrl String?
  smartleadCampaignId Int?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  prospects          Prospect[]
  templates          CommunicationTemplate[]
  commLogs           CommunicationLog[]
  signals            ProspectSignal[]

  @@index([tenantId])
}

model Prospect {
  id              String             @id @default(cuid())
  campaignId      String
  campaign        Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name            String
  firstName       String?
  company         String?
  jobTitle        String?
  painPoint       String?
  phone           String?
  whatsapp        String?
  email           String?
  linkedinUrl     String?
  qualifiedAt     DateTime?
  qualifiedReason String?
  createdAt       DateTime           @default(now())
  commLogs        CommunicationLog[]
  signals         ProspectSignal[]

  @@index([campaignId])
}

model ProspectSignal {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  type       String
  source     String
  content    String
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([campaignId])
  @@index([prospectId])
  @@index([campaignId, prospectId])
}

model CommunicationLog {
  id               String    @id @default(cuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaignId       String
  campaign         Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  prospectId       String
  prospect         Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  channel          String
  templateId       String?
  stage            Int?
  subject          String?
  message          String
  ctaType          String?
  status           String    @default("planned")
  sentAt           DateTime  @default(now())
  deliveredAt      DateTime?
  openedAt         DateTime?
  ctaClickedAt     DateTime?
  responseType     String?
  responseAt       DateTime?
  responseContent  String?
  signalRef        String?
  decisionReason   String?
  modelUsed        String?
  providerUsage    Json?
  providerCost     Json?
  deliveryProvider String?
  deliveryMeta     Json?
  createdAt        DateTime  @default(now())

  @@index([tenantId])
  @@index([tenantId, sentAt])
  @@index([campaignId])
  @@index([prospectId])
  @@index([campaignId, prospectId])
}

model CommunicationTemplate {
  id                      String   @id @default(cuid())
  campaignId              String
  campaign                Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  channel                 String
  stage                   Int      @default(1)
  subject                 String?
  body                    String
  cta                     String
  whatsappTemplateId      String?
  whatsappVariableMapping Json?
  createdAt               DateTime @default(now())

  @@index([campaignId])
}
